        "    optimizer.m = {k: v.copy() for k, v in checkpoint[\"optimizer_state\"][\"m\"].items()}\n",
        "    optimizer.v = {k: v.copy() for k, v in checkpoint[\"optimizer_state\"][\"v\"].items()}\n",
        "    optimizer"
